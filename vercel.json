{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/:action", "destination": "/api/auth/[action]" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/app.html", "destination": "/public/app.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
